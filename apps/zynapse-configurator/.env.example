# ─── Supabase (existent) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ─── n8n (existent, optional) ──────────────────────────────────────────
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://www.ai-nord-vest.com/webhook/zynapse-electrical

# ─── URL site (pt. return/confirm URLs Netopia) ────────────────────────
NEXT_PUBLIC_BASE_URL=https://www.zynapse.org

# ─── Netopia (plată — SANDBOX întâi) ───────────────────────────────────
# Mediu: "sandbox" (test) sau "live" (productie) — controleaza endpoint-ul folosit.
NETOPIA_ENV=sandbox
NETOPIA_SANDBOX_URL=https://sandboxsecure.mobilpay.ro
NETOPIA_LIVE_URL=https://secure.mobilpay.ro

# Signature = string-ul POS din contul Netopia. Tine-l in env.
NETOPIA_SIGNATURE=your_pos_signature_here

# public.cer = certificatul public Netopia (cripteaza cererea). Pune CONTINUTUL fisierului
# ca text PEM, cu BEGIN/END (multilinie intre ghilimele SAU pe o linie cu \n intre randuri).
NETOPIA_PUBLIC_CER="-----BEGIN CERTIFICATE-----\n...continutul_public.cer...\n-----END CERTIFICATE-----"

# private.key = cheia privata Netopia (decripteaza IPN-ul). CONTINUTUL fisierului ca text PEM.
# SECRET — NU in cod, NU in fisiere comise; doar in env (Vercel + .env.local local).
NETOPIA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...continutul_private.key...\n-----END PRIVATE KEY-----"
